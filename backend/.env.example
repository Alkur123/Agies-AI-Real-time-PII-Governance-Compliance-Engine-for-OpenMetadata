# ── Required ────────────────────────────────────────────────────────
# Get from https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# MongoDB Atlas connection string
MONGO_URL=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/governance_logs?retryWrites=true&w=majority
DB_NAME=governance_logs

# ── API Authentication ───────────────────────────────────────────────
# Optional: set a static API key to protect endpoints
API_KEY=

# ── Redis session persistence ────────────────────────────────────────
# Docker: redis://redis:6379  |  Local: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ── LLM config ──────────────────────────────────────────────────────
MODEL=meta-llama/llama-4-scout-17b-16e-instruct
OLLAMA_URL=http://localhost:11434/api/generate

# ── Server config ────────────────────────────────────────────────────
GUNICORN_WORKERS=2
LOG_LEVEL=info
RATE_LIMIT=60/minute

# Comma-separated allowed CORS origins (include your frontend URL)
# Local:  http://localhost:5173,http://localhost:5174
# AWS:    https://your-cloudfront-domain.cloudfront.net
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

SELF_URL=http://localhost:8000

# ── OpenMetadata Integration ─────────────────────────────────────────
# Docker Compose internal: http://openmetadata-server:8585
# Local / EC2:             http://localhost:8585
OM_HOST=http://localhost:8585

# OM JWT token — leave blank to use username/password login below
OM_TOKEN=

# OM admin credentials
OM_USERNAME=admin@openmetadata.org
OM_PASSWORD=Admin@1234
